rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed()       { return request.auth != null; }
    function userRole()       { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; }
    function isAdmin()        { return isAuthed() && userRole() in ['admin', 'intech_owner']; }
    function isMinter()       { return isAuthed() && userRole() == 'minter'; }
    function isConsultant()   { return isAuthed() && userRole() == 'consultant'; }
    function isOmbudsman()    { return isAuthed() && userRole() == 'ombudsman'; }
    function isAuditor()      { return isAuthed() && userRole() == 'auditor'; }

    // Users
    match /users/{userId} {
      allow read:   if request.auth.uid == userId || isAdmin();
      allow create: if false;
      allow update: if request.auth.uid == userId &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'kyc_tier', 'status']);
      allow delete: if false;
    }

    // TROT registrations
    match /trot_registrations/{registrationId} {
      allow read: if isAuthed() && (resource.data.applicantId == request.auth.uid || isAdmin() || isAuditor());
      allow write: if false;
    }

    // Projects
    match /ftr_projects/{projectId} {
      allow read:  if isAuthed() && (resource.data.minterId == request.auth.uid || isAdmin() || isAuditor() || resource.data.status == 'Live');
      allow write: if false;
    }

    // FTR units (own holder + admins)
    match /ftr_units/{unitId} {
      allow read:  if isAuthed() && (resource.data.holderId == request.auth.uid || resource.data.minterId == request.auth.uid || isAdmin() || isAuditor());
      allow write: if false;
    }

    // ROI overrides (consultant + admin)
    match /roi_overrides/{overrideId} {
      allow read:  if isAuthed() && (resource.data.consultantId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // Swap / redemption records
    match /swap_transactions/{txId} {
      allow read:  if isAuthed() && (resource.data.partyAId == request.auth.uid || resource.data.partyBId == request.auth.uid || isAdmin());
      allow write: if false;
    }
    match /redemptions/{redemptionId} {
      allow read:  if isAuthed() && (resource.data.holderId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // Complaints / disputes
    match /complaints/{caseId} {
      allow read:  if isAuthed() && (resource.data.filedBy == request.auth.uid || resource.data.respondent == request.auth.uid || resource.data.ombudsman == request.auth.uid || isAdmin() || isAuditor());
      allow write: if false;
    }

    // MICS digest cache — public aggregate
    match /mics_digest/{docId}   { allow read: if true;  allow write: if false; }
    match /mics_drill/{docId}    { allow read: if true;  allow write: if false; }

    // Platform config
    match /platform_config/{configId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    // Country ROI catalogue
    match /country_roi/{countryCode} {
      allow read:  if true;      // Public — this is a rate card
      allow write: if isAdmin();
    }

    // Audit trail
    match /audit_trail/{logId} {
      allow read:   if isAdmin() || isAuditor();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /{document=**} {
      allow read:  if false;
      allow write: if false;
    }
  }
}
