# ─── IRG_FTR Backend — environment ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/irg_ftr
PORT=3001

# ─── IRG Chain 888101 integration ───────────────────────────────────────────
# These MUST match the Django (GDP) backend settings so both apps push
# transactions through the same middleware instance onto the same chain.

# URL of the middleware service (whichever copy is actually running —
# the mirrored copies in each repo are identical by design).
IRG_CHAIN_MIDDLEWARE_URL=http://irg-middleware.irg-chain.svc.cluster.local:3100

# HMAC shared secret. Generate once with: openssl rand -hex 32
# Must equal the middleware's MIDDLEWARE_SHARED_SECRET and the Django
# setting BLOCKCHAIN_CONFIG['MIDDLEWARE_SHARED_SECRET'].
IRG_CHAIN_MIDDLEWARE_SECRET=

# Bearer token the middleware uses when POSTing audit callbacks back to
# this Node backend at /api/v1/chain/audit.
IRG_CHAIN_AUDIT_TOKEN=

# Read-only RPC (for occasional status probes — not the submission path).
IRG_CHAIN_RPC_URL=https://rpc.irg-chain.com
IRG_CHAIN_ID=888101

# Safety valves
IRG_CHAIN_SUBMIT_TIMEOUT_MS=15000
IRG_CHAIN_SUBMIT_RETRIES=3
IRG_CHAIN_ALLOW_SIMULATE=true   # flip to false in prod

# ─── Contract addresses on IRG Chain 888101 ─────────────────────────────────
# Populate after each deployment. Blank = audit-log-only (simulated hash).
ADDR_FTR_TOKEN=
ADDR_FTR_REDEMPTION=
ADDR_P2P_SETTLEMENT=
ADDR_SUPER_CORPUS=
ADDR_IDENTITY_REGISTRY=
ADDR_IPR_LICENSE=
ADDR_DEVICE_P2P=
ADDR_GIC_LEDGER=
ADDR_ROI_REGISTRY=
