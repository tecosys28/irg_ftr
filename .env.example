# ═════════════════════════════════════════════════════════════════════════════
# irg_ftr — Environment Configuration
# ═════════════════════════════════════════════════════════════════════════════

# ─── Firebase (this project — irg-ftr-prod) ──────────────────────────────────
FIREBASE_PROJECT_ID=irg-ftr-prod
GOOGLE_APPLICATION_CREDENTIALS=/secrets/irg-ftr-prod-service-account.json
# Alternative: FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# Frontend (Vite)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=irg-ftr-prod.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=irg-ftr-prod
VITE_FIREBASE_STORAGE_BUCKET=irg-ftr-prod.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Backend ────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
DATABASE_URL=postgresql://irg_ftr:secret@127.0.0.1:5432/irg_ftr

# ─── Chain (read-only) ──────────────────────────────────────────────────────
CHAIN_RPC_URL=https://rpc.irg-chain-prod.cloudfunctions.net
